#!/usr/bin/bash

CHANNEL_CONF_PATH=/etc/epkg-confs

cache_repo_index()
{
	local repo_url=$1
	local local_cache_path=$HOME/.cache/epkg/channel/${repo_url##*/channel/}

	# clean old metadata files and re-init metadata dir
	rm -rf ${local_cache_path} && \
	mkdir -p ${local_cache_path}/store-paths


	# sync repo metadata from local path
	[[ $repo_url =~ ^/ ]] && {
		cp -r $repo_url/store-paths/initial-release.zst ${local_cache_path}/store-paths/
		cp -r $repo_url/pkg-info.tar.zst ${local_cache_path}/
		cp -r $repo_url/metadata.json ${local_cache_path}/
	}

	# sync repo metadata from http urls
	[[ $repo_url =~ ^http ]] && {
		wget --tries=3 -q $repo_url/store-paths/initial-release.zst -O ${local_cache_path}/store-paths/initial-release.zst.tmp && \
		mv ${local_cache_path}/store-paths/initial-release.zst.tmp ${local_cache_path}/store-paths/initial-release.zst

		wget --tries=3 -q $repo_url/pkg-info.tar.zst -O ${local_cache_path}/pkg-info.tar.zst.tmp && \
		mv ${local_cache_path}/pkg-info.tar.zst.tmp ${local_cache_path}/pkg-info.tar.zst

		wget --tries=3 -q $repo_url/metadata.json -O ${local_cache_path}/metadata.json.tmp && \
		mv ${local_cache_path}/metadata.json.tmp ${local_cache_path}/metadata.json
	}

	[[ -f ${local_cache_path}/store-paths/initial-release.zst ]] && \
	[[ -f ${local_cache_path}/pkg-info.tar.zst ]] && \
	[[ -f ${local_cache_path}/metadata.json ]] || {
		echo "Failed to sync metadata for repo:"
		echo "	${repo_url}"

		rm -rf ${local_cache_path}

		return
	}

	# cached medatata file should be decompressed
	zstd -d ${local_cache_path}/store-paths/initial-release.zst
	tar --use-compress-program=zstd -xf ${local_cache_path}/pkg-info.tar.zst -C ${local_cache_path}/
}

loop_cache_repos()
{
	local channel_conf_file=$1

	local channel_conf_content=$(cat $channel_conf_file)

	for i in $(seq 1 100)
	do
		channel_content=$(echo "${channel_conf_content}" | jq '.channel["'$i'"]')
	
		[[ ${channel_content} == null ]] && break
	
		repo_enable_code=$(echo ${channel_content} | jq '.enabled' | tr -d '"')
	
		# skip cache metadata for disabled repos
		[[ ${repo_enable_code} == 1 ]] || continue
	
		repo_url=$(echo ${channel_content} | jq '.url' | tr -d '"')
	
		[[ -z ${repo_url} ]] && continue

		cache_repo_index $repo_url
	done
}

main()
{
	for repo_conf_file in $(find $CHANNEL_CONF_PATH} -name *.json)
	do
		loop_cache_repos ${repo_conf_file}
	done
}

main
